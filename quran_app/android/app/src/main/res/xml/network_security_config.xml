<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production Quran API domains — HTTPS only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.quran.com</domain>
        <domain includeSubdomains="true">verses.quran.com</domain>
        <domain includeSubdomains="true">cdn.qurancdn.com</domain>
    </domain-config>

    <!-- Local AI microservice — cleartext HTTP allowed on loopback only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Android emulator: 10.0.2.2 reaches the host machine -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
